# 서버
PORT=8080
ENV=development  # development | production

# 데이터베이스
DB_URL=postgres://dottie:dottie_local@localhost:5432/dottie?sslmode=disable

# Firebase
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}  # JSON string

# 카카오 (서버에서 토큰 검증용)
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.xxx

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=dottie-media
R2_PUBLIC_URL=https://media.dottie.app

# CORS
CORS_ORIGINS=http://localhost:3000,https://dottie.app
